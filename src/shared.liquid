{% capture matomo_landing_pages_table %}
  <table class="table table--condensed" data-table-limit="true">
    <thead>
      <tr>
        <th class="text--left"><span class="title title--small">Path</span></th>
        <th class="text--right w--[15cqw]"><span class="title title--small">Pageviews</span></th>
        <th class="text--right w--[15cqw]"><span class="title title--small">Visits</span></th>
        <th class="text--right w--[15cqw]"><span class="title title--small">Bounce Rate</span></th>
      </tr>
    </thead>
    <tbody>
      {% for page in matomo_landing_pages_list %}
        <tr>
          <td class="text--left"><span class="label label--small">{{ page.label }}</span></td>
          <td class="text--right"><span class="value value--xxsmall lg:value--xsmall" data-value-format="true" data-value-locale="{{ trmnl.user.locale }}">{{ page.nb_hits }}</span></td>
          <td class="text--right"><span class="value value--xxsmall lg:value--xsmall" data-value-format="true" data-value-locale="{{ trmnl.user.locale }}">{{ page.nb_visits }}</span></td>
          <td class="text--right"><span class="value value--xxsmall lg:value--xsmall">{{ page.bounce_rate }}</span></td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endcapture %}

