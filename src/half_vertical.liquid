{%
#################
# Metrics
#################
%}
{% if matomo_active_view == 'metrics' %}
<div class="layout layout--col gap--space-between">
  <div class="grid grid--cols-2">
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <div class="w--14 h--1.5 mb--2 bg--black rounded--large"></div>
        <span class="value value--base lg:value--large  value--medium lg:value--large  value--tnums" data-value-format="true" data-value-format="true" data-value-locale="{{ matomo_locale }}">{{ total_pageviews }}</span>
        <span class="label label--base lg:label--large">Pageviews</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <div class="w--14 h--1.5 mb--2 bg--gray-5 rounded--large"></div>
        <span class="value value--base lg:value--large value--tnums" data-value-format="true" data-value-format="true" data-value-locale="{{ matomo_locale }}">{{ total_visitors }}</span>
        <span class="label label--base lg:label--large">Visitors</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base lg:value--large value--tnums">{{ time_display }}</span>
        <span class="label label--base lg:label--large">Time on Site</span>
      </div>
    </div>
  </div>

  <div id="{{ chart_id }}" class="w--full h--52 lg:h--96"></div>
</div>

<script>
  const chartId = {{ chart_id | json }};
  createMatomoChart(chartId);
</script>
{% endif %}

{%
#################
# Landing Pages
#################
%}
{% if matomo_active_view == 'landing_pages' %}
<div class="layout layout--col gap--space-between">
  <div class="text--center">
    <div class="title title--large lg:title--xlarge">Top Landing Pages</div>
    <span class="description description--base lg:description--large">{{ date_range_display }}</span>
  </div>

  {{ matomo_landing_pages_table_compact }}
</div>
{% endif %}

{%
#################
# Top Referrers
#################
%}
