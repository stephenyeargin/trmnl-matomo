{%
#################
# Metrics
#################
%}
{% if matomo_active_view == 'metrics' %}
<div class="layout layout--col gap--space-between">
  <div class="grid grid--cols-2 gap--large lg:gap--xlarge">
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--medium lg:value--large value--tnums" data-value-format="true" data-value-format="true" data-value-locale="{{ matomo_locale }}">{{ total_pageviews }}</span>
        <span class="label label--medium lg:label--large">Pageviews</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--medium lg:value--large value--tnums" data-value-format="true" data-value-format="true" data-value-locale="{{ matomo_locale }}">{{ total_visitors }}</span>
        <span class="label label--medium lg:label--large">Visitors</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--medium lg:value--large value--tnums">{{ time_display }}</span>
        <span class="label label--medium lg:label--large">Time on Site</span>
      </div>
    </div>
  </div>
</div>
{% endif %}

{%
#################
# Landing Pages
#################
%}
{% if matomo_active_view == 'landing_pages' %}
<div class="layout layout--col gap--space-between">
  {{ matomo_landing_pages_table_tiny }}
</div>
{% endif %}

{%
#################
# Top Referrers
#################
%}
{% if matomo_active_view == 'top_referrers' %}
<div class="layout layout--col gap--space-between">
  {{ matomo_referrers_table_tiny }}
</div>
{% endif %}

{%
#################
# Top Countries
#################
%}
{% if matomo_active_view == 'top_countries' %}
<div class="layout layout--col gap--space-between">
  {{ matomo_countries_table_tiny }}
</div>
{% endif %}

<div class="title_bar">
  <img class="image image-stroke--medium" src="data:image/svg+xml;base64,{{ logo_svg | base64_encode }}" />
  <span class="title">{{ matomo_site_name }}</span>
</div>
